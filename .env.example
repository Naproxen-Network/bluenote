# Copy to .env for Docker Compose and export the same values before starting Java services.
LBN_DB_USER=root
LBN_DB_PASSWORD=lbn_dev_password
LBN_DB_PORT=3306
LBN_DB_URL=jdbc:mysql://127.0.0.1:3306/little_blue_note?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC&useSSL=false&allowPublicKeyRetrieval=true
LBN_REDIS_HOST=127.0.0.1
LBN_REDIS_PORT=6379
LBN_RABBIT_HOST=127.0.0.1
LBN_RABBIT_PORT=5672
LBN_RABBIT_USER=lbn
LBN_RABBIT_PASSWORD=lbn_dev_password
LBN_NACOS_ADDR=127.0.0.1:8848
# Required: generate a unique random value containing at least 32 UTF-8 bytes.
LBN_JWT_SECRET=
LBN_WS_ALLOWED_ORIGINS=http://127.0.0.1:*,http://localhost:*
